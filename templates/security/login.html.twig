{% extends 'base.html.twig' %}

{% block title %}Connexion — Adlance{% endblock %}

{% block body %}
<article style="max-width: 400px; margin: 4rem auto;">
    <header>
        <h2>Connexion</h2>
    </header>

    {% if error %}
        <p role="alert" style="color: var(--pico-color-red-500);">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
    {% endif %}

    <form method="post">
        <label for="email">Email
            <input type="email" id="email" name="_username" value="{{ last_username }}" required autofocus>
        </label>
        <label for="password">Mot de passe
            <input type="password" id="password" name="_password" required>
        </label>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit">Se connecter</button>
    </form>

    <footer>
        <small>Pas encore de compte ? <a href="{{ path('app_register') }}">Créer un compte</a></small>
    </footer>
</article>
{% endblock %}
